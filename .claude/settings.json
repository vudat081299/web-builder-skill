{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/wb-sync-reminder.sh\"",
            "timeout": 10,
            "statusMessage": "web-builder: checking component sync"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-gate.sh\"",
            "timeout": 30,
            "statusMessage": "web-builder: validating before commit/push"
          }
        ]
      }
    ]
  }
}
